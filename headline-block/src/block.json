{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/headline-block",
	"version": "0.1.0",
	"title": "Headline Block",
	"category": "widgets",
	"icon": "smiley",
	"description": "Example block scaffolded with Create Block tool.",
	"example": {},
	"supports": {
		"html": false
	},
	"textdomain": "headline-block",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js",
	"attributes": {
		"headline_content": {
			"type": "rich-text",
			"source": "rich-text",
			"selector": "h1"
		},
		"kicker_content": {
			"type": "rich-text",
			"source": "rich-text",
			"selector": ".kicker"
		},
		"kicker_bg_color": {
			"type": "string",
			"selector": ".kicker"
		},
		"headline_text_color": {
			"type": "string",
			"selector": "h1"
		}
	}
}
