{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/gutenberg-game-day",
	"version": "0.1.0",
	"title": "Gutenberg Game Day",
	"category": "widgets",
	"icon": "smiley",
	"description": "Example block scaffolded with Create Block tool.",
	"example": {},
	"supports": {
		"html": false
	},
	"textdomain": "gutenberg-game-day",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js",
	"attributes": {
		"kicker": {
			"type": "string",
			"source": "html",
			"selector": "h4"
		},
		"headline": {
			"type": "string",
			"source": "html",
			"selector": "h2"
		},
		"subdeck": {
			"type": "string",
			"source": "html",
			"selector": "h3"
		},
		"headlineColour": {
			"type": "string"
		},
		"kickerBackgroundColour": {
			"type": "string"
		},
		"is90sMode": {
			"type": "boolean",
			"default": false
		}
	}
}
